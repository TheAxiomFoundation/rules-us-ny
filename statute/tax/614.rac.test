# Tests for 614.rac

tests:
    - name: "Single"
      inputs:
        filing_status: single
      expect: 8000
    - name: "Married filing jointly"
      inputs:
        filing_status: married_filing_jointly
      expect: 16050
    - name: "Head of household"
      inputs:
        filing_status: head_of_household
      expect: 11200
