# Tests for 606/b.rac

tests:
    - name: "Single, under income limit"
      inputs:
        filing_status: single
        federal_agi: 25000
      expect: 90
    - name: "Single, over income limit"
      inputs:
        filing_status: single
        federal_agi: 30000
      expect: 0
    - name: "Joint, under income limit"
      inputs:
        filing_status: married_filing_jointly
        federal_agi: 30000
      expect: 180
    - name: "HOH, at income limit"
      inputs:
        filing_status: head_of_household
        federal_agi: 28000
      expect: 130
