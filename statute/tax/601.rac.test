# Tests for 601.rac

tests:
    - name: "Single filer, $50k AGI"
      period: 2024-01
      inputs:
        federal_agi: 50000
        filing_status: single
        ny_standard_deduction: 8000
      # Taxable = $42,000
      expect: 2316
    - name: "Joint filers, $100k AGI"
      period: 2024-01
      inputs:
        federal_agi: 100000
        filing_status: married_filing_jointly
        ny_standard_deduction: 16050
      # Taxable = $83,950
      expect: 4361
