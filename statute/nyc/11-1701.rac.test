# Tests for 11-1701.rac

tests:
    - name: "Single NYC resident, $40k taxable income"
      inputs:
        ny_taxable_income: 40000
        filing_status: single
      # 12k at 3.078% + 13k at 3.762% + 15k at 3.819%
      # = $369.36 + $489.06 + $572.85 = $1,431.27
      expect: 1431
    - name: "Joint NYC resident, $80k taxable income"
      inputs:
        ny_taxable_income: 80000
        filing_status: married_filing_jointly
      # 21.6k at 3.078% + 23.4k at 3.762% + 35k at 3.819%
      # = $664.85 + $880.31 + $1,336.65 = $2,881.81
      expect: 2882
